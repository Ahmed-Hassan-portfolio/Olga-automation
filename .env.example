# OLGA Automation — Environment Configuration
# Copy this file to .env and fill in values for your local OLGA install.

# Path to your OLGA installation root
OLGA_HOME=/path/to/your/OLGA/install

# Path to the opi.exe binary (usually OLGA_HOME/bin/opi.exe on Windows)
OPI_COMMAND=/path/to/your/OLGA/install/bin/opi.exe

# Optional: license server location
LM_LICENSE_FILE=

# Max parallel simulation runs (license count usually caps this)
MAX_PARALLEL_RUNS=1

# Default OpenMP threads per simulation
THREADS_PER_RUN=1

# Default per-simulation timeout, in seconds (2 hours)
DEFAULT_TIMEOUT=7200
